{
  "name": "@lattica/collab",
  "version": "0.1.0",
  "description": "Realtime collaboration primitives for Lattica: a table-specific LWW CRDT, fractional indexing for stable row/column order, presence, and a transport abstraction.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lattica/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
