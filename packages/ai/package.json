{
  "name": "@lattica/ai",
  "version": "0.1.0",
  "description": "AI-native spreadsheet primitives for Lattica: provider-agnostic AI client, undoable AICommand with provenance, NL<->formula, AI columns, smart fill, schema inference, semantic search.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit" },
  "dependencies": { "@lattica/core": "workspace:*", "@lattica/formula": "workspace:*", "@lattica/data": "workspace:*" },
  "publishConfig": { "access": "public" }
}
