{
  "name": "@lattica/data",
  "version": "0.1.0",
  "description": "Index mapping (physical<->visual) and data-source binding for Lattica: the foundation for hiding, moving, sorting, filtering, trimming, and grouping.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit" },
  "dependencies": { "@lattica/core": "workspace:*" },
  "publishConfig": { "access": "public" }
}
